<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.25.xsd">
    
    <!-- Users table -->
    <changeSet id="001" author="effie">
        <createTable tableName="users">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="username" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="password" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="email" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="role" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="enabled" type="BOOLEAN" defaultValue="true">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
    </changeSet>
    
    <!-- Transactions table -->
    <changeSet id="002" author="effie">
        <createTable tableName="transactions">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="pain_message_id" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="transaction_id" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="amount" type="DECIMAL(19,4)">
                <constraints nullable="false"/>
            </column>
            <column name="currency" type="VARCHAR(3)">
                <constraints nullable="false"/>
            </column>
            <column name="value_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="sender_name" type="VARCHAR(255)"/>
            <column name="sender_account" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="receiver_name" type="VARCHAR(255)"/>
            <column name="receiver_account" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="payment_title" type="VARCHAR(500)"/>
            <column name="status" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="authorized_by" type="VARCHAR(255)"/>
            <column name="approved_by" type="VARCHAR(255)"/>
            <column name="rejection_reason" type="VARCHAR(500)"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>
    </changeSet>
    
    <!-- Audit logs table -->
    <changeSet id="003" author="effie">
        <createTable tableName="audit_logs">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="entity_type" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="entity_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="action" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT"/>
            <column name="username" type="VARCHAR(255)"/>
            <column name="details" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
    </changeSet>
    
    <!-- Spring Modulith Event Publications table -->
    <changeSet id="004" author="effie">
        <createTable tableName="event_publications">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="publication_id" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="event" type="CLOB">
                <constraints nullable="false"/>
            </column>
            <column name="content_type" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="listener_id" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="creation_time" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="completion_time" type="TIMESTAMP"/>
            <column name="last_attempt" type="TIMESTAMP"/>
            <column name="attempts" type="INT" defaultValue="0">
                <constraints nullable="false"/>
            </column>
            <column name="max_attempts" type="INT" defaultValue="3">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    
    <!-- Indexes -->
    <changeSet id="005" author="effie">
        <createIndex indexName="idx_transactions_status" tableName="transactions">
            <column name="status"/>
        </createIndex>
        <createIndex indexName="idx_transactions_created" tableName="transactions">
            <column name="created_at"/>
        </createIndex>
        <createIndex indexName="idx_audit_logs_entity" tableName="audit_logs">
            <column name="entity_type"/>
            <column name="entity_id"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
